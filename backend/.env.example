# Which LLM to use for routing + synthesis: "claude" or "gemini"
LLM_PROVIDER=claude

# Provide the key for whichever provider is selected.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional model overrides (leave blank to use the code's current default)
CLAUDE_MODEL=
GEMINI_MODEL=

# Local embeddings (no key needed)
EMBED_MODEL=all-MiniLM-L6-v2

# Ingestion window
INGEST_DATE_START=2020-01-01
INGEST_DATE_END=

# Storage
CHROMA_DIR=./data/chroma
CACHE_DIR=./data/cache
